{
  "name": "pld-workbench",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run build && bun ./scripts/serve.ts",
    "build": "rm -rf dist && mkdir -p dist && bun run build:css && bun build ./src/main.tsx --outdir ./dist --target browser --minify && cp index.html dist/index.html",
    "build:css": "tailwindcss -i ./src/styles/globals.css -o ./dist/globals.css",
    "seed:transaction-case": "bun ./scripts/seed-transaction-case.ts",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:real": "PLD_TRANSACTION_E2E=true playwright test e2e/transaction-signal.e2e.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-query": "^5.59.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.1.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
