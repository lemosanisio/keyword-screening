{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManualReviewRequested.v2",
  "description": "Pedido operacional único por avaliação LIVE. O consumidor deduplica por (sourceSystem, reviewRequestId) e registra localmente a política de agrupamento aplicada.",
  "allOf": [
    { "$ref": "common/envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "ManualReviewRequested" },
        "eventVersion": { "const": 2 },
        "producer": { "const": "pld-transaction-screening" },
        "payload": {
          "type": "object",
          "required": [
            "reviewRequestId",
            "evaluationId",
            "transactionId",
            "signalIds",
            "reasonCodes",
            "recommendedRoute"
          ],
          "properties": {
            "reviewRequestId": {
              "type": "string",
              "pattern": "^rrq_[0-9A-HJKMNP-TV-Z]{26}$"
            },
            "evaluationId": {
              "type": "string",
              "pattern": "^evl_[0-9A-HJKMNP-TV-Z]{26}$",
              "description": "Existe no máximo um pedido de revisão por evaluationId."
            },
            "transactionId": {
              "type": "string",
              "pattern": "^txn_[0-9A-HJKMNP-TV-Z]{26}$"
            },
            "signalIds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^sig_[0-9A-HJKMNP-TV-Z]{26}$"
              },
              "description": "Lista autoritativa de sinais associados; pode ser vazia para revisão causada apenas por indeterminação."
            },
            "reasonCodes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "INSUFFICIENT_EVIDENCE",
                  "CONFLICTING_EVIDENCE",
                  "LOW_IDENTITY_CONFIDENCE",
                  "SOURCE_UNAVAILABLE",
                  "STALE_EVIDENCE",
                  "POLICY_REQUIRES_REVIEW",
                  "HIGH_IMPACT_ACTION",
                  "UNCLASSIFIED_SITUATION"
                ]
              }
            },
            "recommendedRoute": {
              "enum": ["DERIVED_TO_ANALYST", "MANDATORY_SECOND_APPROVAL"]
            }
          }
        }
      }
    }
  ]
}
