{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CustomerDataChanged.v1",
  "description": "Alteração cadastral publicada pelo sistema mestre. O evento carrega os valores novos (event-carried state): fidelidade temporal do gatilho de revisão e zero chamada síncrona na ingestão. pld-customer-analysis versiona o snapshot e avalia gatilho de EVENT_DRIVEN_REVIEW. Proposta de contrato ao sistema mestre (EXT-2).",
  "allOf": [
    { "$ref": "common/envelope.schema.json" },
    {
      "type": "object",
      "properties": {
        "eventType": { "const": "CustomerDataChanged" },
        "eventVersion": { "const": 1 },
        "producer": { "const": "external" },
        "payload": {
          "type": "object",
          "required": [
            "sourceSystem",
            "externalPartyRef",
            "changedFields",
            "changedAt"
          ],
          "properties": {
            "sourceSystem": {
              "type": "string",
              "minLength": 1
            },
            "externalPartyRef": {
              "type": "string",
              "minLength": 1,
              "description": "Referência opaca da parte no sistema mestre."
            },
            "changedFields": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["field", "newValue", "source"],
                "properties": {
                  "field": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Nome canônico do campo alterado."
                  },
                  "newValue": {
                    "description": "Valor novo do campo; tipo livre conforme o campo. PII viaja classificada CONFIDENTIAL."
                  },
                  "source": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Fonte do valor (CA-FR-001: cada campo registra fonte e validade)."
                  },
                  "validFrom": { "type": "string", "format": "date" },
                  "validUntil": { "type": ["string", "null"], "format": "date" }
                }
              }
            },
            "changedAt": {
              "type": "string",
              "format": "date-time"
            },
            "changeReason": {
              "type": "string",
              "description": "Motivo da alteração; vocabulário do sistema mestre."
            }
          }
        }
      }
    }
  ]
}
